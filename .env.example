TAVILY_API_KEY=
DATABASE_URL=sqlite:///data/processed/metrics.db
DB_AUTO_CREATE_TABLES=1
API_AUTH_TOKEN=
REQUIRE_CHAT_SCOPE=
REGISTRY_BACKEND=auto
ARTIFACT_STORE_BACKEND=auto
VECTOR_ARTIFACT_SYNC_INTERVAL_SECONDS=30

# LLM and evaluation (HuggingFace)
HF_TOKEN=
HF_MODEL=katanemo/Arch-Router-1.5B
HF_BASE_URL=https://router.huggingface.co/v1
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_API_URL=
HF_RAGAS_MODEL=katanemo/Arch-Router-1.5B
HF_RAGAS_ENDPOINT=

# Storage
AWS_REGION=us-east-1
S3_FAISS_BUCKET=
S3_FAISS_KEY=faiss/legal_contracts/index.tar.gz

# API runtime
API_BASE_URL=http://localhost:8000
OLLAMA_MODEL=mistral
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_CONNECT_TIMEOUT_SECONDS=5
OLLAMA_CLI_TIMEOUT_SECONDS=20
OLLAMA_JUDGE_TIMEOUT_SECONDS=20
HF_EMBEDDING_LOCAL_ONLY=1
PIPELINE_QUERY_TIMEOUT_SECONDS=90
